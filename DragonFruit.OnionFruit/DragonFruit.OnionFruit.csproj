<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <PropertyGroup>
    <AssemblyTitle>OnionFruit™</AssemblyTitle>
    <Description>Tor access client</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="DragonFruit.Data" />
    <PackageReference Include="DragonFruit.Data.Roslyn" />
    <PackageReference Include="DiscordRichPresence" />
    <PackageReference Include="FluentAvaloniaUI" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools" PrivateAssets="all" />
    <PackageReference Include="LucideAvalonia" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Nito.AsyncEx.Coordination" />
    <PackageReference Include="ReactiveUI.Avalonia" />
    <PackageReference Include="Svg.Controls.Skia.Avalonia" />
    <PackageReference Include="Velopack" />
    <PackageReference Include="Xaml.Behaviors.Avalonia" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\*.ico" />
    <AvaloniaResource Include="Assets\*.svg" />
    <AvaloniaResource Include="Assets\*.ttf" />
    <Protobuf Include="Protos\*.proto">
      <GrpcServices>Both</GrpcServices>
      <Access>Public</Access>
    </Protobuf>
  </ItemGroup>

  <ItemGroup>
    <None Include="Assets\nuget-licenses.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      <CopyToPublishDirectory>Always</CopyToPublishDirectory>
      <Link>nuget-licenses.json</Link>
    </None>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DragonFruit.OnionFruit.Core\DragonFruit.OnionFruit.Core.csproj" />
  </ItemGroup>
</Project>